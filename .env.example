# Redis connection. Vercel injects these automatically when you install
# the Upstash for Redis integration from the Vercel Marketplace.
# (Older @vercel/kv stores also use KV_REST_API_* — either works.)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Full service account JSON, base64-encoded.
# On Mac: base64 -i credentials.json | pbcopy
GOOGLE_SERVICE_ACCOUNT_JSON=

# Random 32+ char string for signing the session cookie.
# Generate: openssl rand -base64 48
COOKIE_SECRET=
